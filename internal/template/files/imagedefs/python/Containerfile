FROM docker.io/library/python:3.12-bookworm

RUN apt-get update && apt-get install -y --no-install-recommends git ca-certificates \
    && rm -rf /var/lib/apt/lists/* \
    && pip install --no-cache-dir uv

WORKDIR /workspace
CMD ["/bin/bash"]
