# NeonRoot arch-dev shell.

# Auto-start tmux for interactive sessions: attach the existing session or start
# a new one (continuum restores the last one). This is where the dev session
# lives — with session saving — so NeonRoot just execs bash and the image owns
# tmux. Guarded so it never nests or fires in scripts.
if command -v tmux >/dev/null 2>&1 && [ -z "$TMUX" ] && [[ $- == *i* ]]; then
  exec tmux new-session -A -s main
fi

export EDITOR=nvim
export VISUAL=nvim

# Modern replacements + handy aliases.
alias ls='eza --group-directories-first'
alias ll='eza -lah --group-directories-first --git'
alias la='eza -a'
alias tree='eza --tree'
alias cat='bat --paging=never'
alias vim='nvim'
alias lg='lazygit'

# Prompt, smart cd, fuzzy finder.
command -v starship >/dev/null && eval "$(starship init bash)"
command -v zoxide  >/dev/null && eval "$(zoxide init bash)"
[ -f /usr/share/fzf/key-bindings.bash ] && source /usr/share/fzf/key-bindings.bash
[ -f /usr/share/fzf/completion.bash ]  && source /usr/share/fzf/completion.bash
